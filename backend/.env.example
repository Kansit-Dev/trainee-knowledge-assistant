# Auth
JWT_SECRET=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (PostgreSQL via docker-compose db service)
POSTGRES_USER=trainee
POSTGRES_PASSWORD=change-me
POSTGRES_DB=knowledge
DATABASE_URL=postgresql://trainee:change-me@db:5432/knowledge

# LLM provider (OpenAI-compatible). Example uses Groq's OpenAI-compatible endpoint.
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Uploads
MAX_UPLOAD_MB=10
UPLOAD_DIR=uploads
